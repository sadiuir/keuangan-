{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "keuangan-1",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": [
    "nodejs_compat",
    "nodejs_compat_populate_process_env"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  }
}
